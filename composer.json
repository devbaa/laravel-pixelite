{
  "name": "boralp/laravel-pixelite",
  "description": "Laravel middleware package for collecting route statistics and analytics",
  "type": "library",
  "version": "1.2.1",
  "autoload": {
    "psr-4": {
      "Boralp\\Pixelite\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Boralp\\Pixelite\\PixeliteServiceProvider"
      ]
    }
  },
  "require": {
    "php": "^8.2",
    "geoip2/geoip2": "^3.2.0"
  },
  "require-dev": {
    "laravel/pint": "^1.24"
  }
}
